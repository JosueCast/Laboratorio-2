<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    tools:context=".MainActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header Azul -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:orientation="vertical"
            android:background="#003D82"
            android:gravity="center"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Registro de Datos"
                android:textSize="32sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Gestión de Información"
                android:textSize="14sp"
                android:textColor="#B3D9FF"
                android:layout_marginTop="5dp" />
        </LinearLayout>

        <!-- Contenido principal -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Card Nombre -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#F8FBFF"
                android:padding="16dp"
                android:layout_marginBottom="15dp"
                android:elevation="2dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Nombre Completo"
                    android:textStyle="bold"
                    android:textSize="14sp"
                    android:textColor="#003D82"
                    android:layout_marginBottom="8dp" />

                <EditText
                    android:id="@+id/editNombre"
                    android:layout_width="match_parent"
                    android:layout_height="45dp"
                    android:hint="Ej: Juan Pérez"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:background="#FFFFFF"
                    android:textSize="15sp"
                    android:textColorHint="#9EAEC4"
                    android:textColor="#003D82"
                    android:elevation="1dp" />
            </LinearLayout>

            <!-- Card Edad -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#F8FBFF"
                android:padding="16dp"
                android:layout_marginBottom="15dp"
                android:elevation="2dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Edad"
                    android:textStyle="bold"
                    android:textSize="14sp"
                    android:textColor="#003D82"
                    android:layout_marginBottom="8dp" />

                <EditText
                    android:id="@+id/editEdad"
                    android:layout_width="match_parent"
                    android:layout_height="45dp"
                    android:hint="Ej: 25"
                    android:inputType="number"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:background="#FFFFFF"
                    android:textSize="15sp"
                    android:textColorHint="#9EAEC4"
                    android:textColor="#003D82"
                    android:elevation="1dp" />
            </LinearLayout>

            <!-- Card Departamento -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#F8FBFF"
                android:padding="16dp"
                android:layout_marginBottom="20dp"
                android:elevation="2dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Departamento"
                    android:textStyle="bold"
                    android:textSize="14sp"
                    android:textColor="#003D82"
                    android:layout_marginBottom="8dp" />

                <Spinner
                    android:id="@+id/spinnerDepartamento"
                    android:layout_width="match_parent"
                    android:layout_height="45dp"
                    android:background="#FFFFFF"
                    android:padding="10dp"
                    android:elevation="1dp" />
            </LinearLayout>

            <!-- Botón Agregar -->
            <Button
                android:id="@+id/btnAgregar"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:text="AGREGAR REGISTRO"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:backgroundTint="#0052CC"
                android:layout_marginBottom="25dp"
                android:elevation="4dp" />

            <!-- Sección Lista -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Registros"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#003D82"
                android:layout_marginBottom="12dp" />

            <!-- ListView con fondo -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:background="#E8F0F8"
                android:padding="2dp"
                android:elevation="2dp">

                <ListView
                    android:id="@+id/listView"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="#FFFFFF" />
            </FrameLayout>

            <!-- Sección Detalles -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Detalles del Registro"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#003D82"
                android:layout_marginTop="25dp"
                android:layout_marginBottom="12dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#F0F5FA"
                android:padding="16dp"
                android:elevation="2dp">

                <TextView
                    android:id="@+id/textViewDetalles"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Selecciona un registro para ver los detalles"
                    android:textSize="15sp"
                    android:textColor="#5A7A8C"
                    android:lineSpacingMultiplier="1.5" />
            </LinearLayout>

            <!-- Espacio inferior -->
            <View
                android:layout_width="match_parent"
                android:layout_height="30dp" />
        </LinearLayout>
    </LinearLayout>

</ScrollView>